			<div class="elementor-widget-wrap elementor-element-populated">
						<div class="elementor-element elementor-element-53285419 elementor-widget elementor-widget-image" data-id="53285419" data-element_type="widget" data-widget_type="image.default">
				<div class="elementor-widget-container">
															<img data-perfmatters-preload fetchpriority="high" decoding="async" width="700" height="462" src="https://www.startasl.com/wp-content/uploads/start-asl-signing-group.png" class="attachment-full size-full wp-image-534823" alt="American Sign Language Signing Group" srcset="https://www.startasl.com/wp-content/uploads/start-asl-signing-group.png 700w, https://www.startasl.com/wp-content/uploads/start-asl-signing-group-80x53.png 80w, https://www.startasl.com/wp-content/uploads/start-asl-signing-group-450x297.png 450w, https://www.startasl.com/wp-content/uploads/start-asl-signing-group-500x330.png 500w" sizes="(max-width: 700px) 100vw, 700px" title="American Sign Language Signing Group | Start ASL" />															</div>
