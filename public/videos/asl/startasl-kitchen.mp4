					<script type="pmdelayedscript" data-cfasync="false" data-no-optimize="1" data-no-defer="1" data-no-minify="1" data-rocketlazyloadscript="1">function myFunction() {var input, filter, ul, li, a, i, txtValue; input = document.getElementById("vocabInput"); filter = input.value.toUpperCase(); ul = document.getElementById("vocabUL"); li = ul.getElementsByTagName("li"); for (i = 0; i < li.length; i++) {a = li[i].getElementsByTagName("a")[0]; txtValue = a.textContent || a.innerText; if (txtValue.toUpperCase().indexOf(filter) > -1) {li[i].style.display = "";} else {li[i].style.display = "none";}}}</script>
