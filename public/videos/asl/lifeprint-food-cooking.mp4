				EAT<br>
				EITHER<br>
				FRUIT-S-A-L-A-D<br>
				GOOD<br>
				GRAPE-F-R-U-I-T<br>
				GRAPES<br>
				GREEN<br>
				GREEN-P-E-P-P-E-R<br>
				H-A-M<br>
				HAPPEN<br>
				HOTDOG<br>
				HOT-DOG<br>
				I<br>
				I'M<br>
				ISLAND<br>
				JELLY<br>
				KETCHUP<br>
				LEMON<br>
				LETTUCE<br>
				LIKE<br>
