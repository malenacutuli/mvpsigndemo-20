accessibility":{"label":"Unsubscribe"},"trackingParams":"CKMBEPBbIhMIve-m3f-djwMVCz_xBR2yaTpw"}},"cancelButton":{"buttonRenderer":{"style":"STYLE_TEXT","size":"SIZE_DEFAULT","isDisabled":false,"text":{"runs":[{"text":"Cancel"}]},"accessibility":{"label":"Cancel"},"trackingParams":"CKIBEPBbIhMIve-m3f-djwMVCz_xBR2yaTpw"}},"primaryIsCancel":false}},"popupType":"DIALOG"}}]}}]}},"metadataRowContainer":{"metadataRowContainerRenderer":{"collapsedItemCount":0,"trackingParams":"CJ8BEM2rARgBIhMIve-m3f-djwMVCz_xBR2yaTpw"}},"showMoreText":{"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"trackingParams":"CJ8BEM2rARgBIhMIve-m3f-djwMVCz_xBR2yaTpw","defaultExpanded":false,"descriptionCollapsedLines":3,"showMoreCommand":{"clickTrackingParams":"CJ8BEM2rARgBIhMIve-m3f-djwMVCz_xBR2yaTpwygEEoqSQMA==","commandExecutorCommand":{"commands":[{"clickTrackingParams":"CJ8BEM2rARgBIhMIve-m3f-djwMVCz_xBR2yaTpwygEEoqSQMA==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_EXPANDED"}},{"clickTrackingParams":"CJ8BEM2rARgBIhMIve-m3f-djwMVCz_xBR2yaTpwygEEoqSQMA==","scrollToEngagementPanelCommand":{"targetId":"engagement-panel-structured-description"}}]}},"showLessCommand":{"clickTrackingParams":"CJ8BEM2rARgBIhMIve-m3f-djwMVCz_xBR2yaTpwygEEoqSQMA==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_HIDDEN"}},"attributedDescription":{"content":"Learn how to talk with your body using sign language! 👋🏼 Dance along with Danny as he learns to sign a few common ASL phrases and plays a silly \"guess the signs\" game!\n\nSpecial thanks to Sandy Wright from the Deaf and Hard of Hearing community + children's ASL teacher Kris Smooke for their help in bringing this video to life! If you're interested in learning more about the work they both do, check out the links below!\n\nCamp Sertoma for Deaf and Hard of Hearing Children - https://campsertomaclub.org/\nTiny Hands Learning (online ASL classes for kids) - https://www.tinyhandslearning.com/\n\nLYRICS:\nTalk, talk, talk\nTalking with my body\nOh, I love moving my body\n\nHello, nice to meet you!\nI am learning to sign.\nGoodbye! See you later, alligator!\n\nTalk, talk, talk\nTalking with my body\nOh, I love moving my body\n\nUnicorn or monkey? MONKEY!\nBanana or apple? BANANA!\nCowboy or astronaut? ASTRONAUT!\nRobot or dinosaur? DINOSAUR!\nFire or ice? FIRE!\nSquirrel or bear? BEAR!\n\nTalk, talk, talk\nTalking with my body\nOh, I love moving my body\n\nJump! Shake! Spin! Clap!\nJump! Shake! Spin! Clap!\n\n-----------------------------------------------------------\n\nWanna keep dancing? Here's some of our other favorite Danny Go dance songs!\n\nThe Floor is Lava Dance -    • \"The Floor is Lava Dance!\" 🌋 /// Danny Go!...  \nThe Cowboy Dance -    • The Cowboy Dance! 🤠 /// Danny Go! Kids Bra...  \nThe Color Dance -    • “The Color Dance Game!” 🌈 /// Would You Ra...  \nThe Ice King Freeze Dance -    • \"The Ice King Freeze Dance!\" 🥶👑 /// Danny ...  \nThe Wiggle Dance Song -    • \"The Wiggle Dance!\" 🪱 /// Danny Go! Brain ...  \nThe Fire \u0026 Ice Freeze Dance -    • \"Fire \u0026 Ice FREEZE Dance!\" 🔥❄️ /// Danny G...  \nThe Robot Dance -    • \"The Robot Dance!\" 🤖 /// Danny Go! Brain B...  \nThe Monkey Dance -    • \"The Monkey Dance!\" 🐵🍌 /// Danny Go! Brain...  \nThe Stomp Clap Dance Song -    • \"The Stomp Clap Dance Song\" 👏🏼/// Danny Go...  \nThe Dinosaur Dance -    • \"The Dinosaur Dance!\" 🦖 /// Danny Go! Brai...  \n\nFor free downloads and other goodies, visit dannygo.net!\n\nGet your kids moving, having fun, being silly and learning with Danny Go! Tired of YouTube simple nursery rhymes? Every Danny Go! video is packed with original songs for kids and dances for kids that even mom, dad, teachers and caretakers can enjoy! Play freeze games, floor is lava games, this or that games, construction vehicle games and more! Dance along with us to songs about cowboys, dinosaurs, monkeys, robots, unicorns, cartoons, diggers, space, cars, and more! When we're not moving and grooving, we will be taking exciting field trips to fire stations, trampoline parks, animal shelters, going on treasure hunts and more. We will see you there!\n\nDanny Go! on Instagram:   / dannygo_official  \nDanny Go! on Facebook:   / dannygoofficial  \nDanny Go! on Cameo: https://www.cameo.com/dannygo\n\nStream Danny Go! music:  \nSpotify - https://open.spotify.com/artist/3DQZd...\nApple Music -   / danny-go  \nAmazon Music - https://music.amazon.com/artists/B07W...\n\n© 2023 Giant Jungle Productions, LLC. All Rights Reserved.","commandRuns":[{"startIndex":478,"length":28,"onTap":{"innertubeCommand":{"clickTrackingParams":"CJ8BEM2rARgBIhMIve-m3f-djwMVCz_xBR2yaTpwSNy3idCXxuvZuAHKAQSipJAw","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbUpyano0Mml2WHpPYXZodFpEN29oOHNDYjdFUXxBQ3Jtc0traTcyMU15czVDbUNrbDU5MzZJcldUenFrRFRIODR4ZHF1QmREUXE4VW15NDZfZnduUXYtYUgxLUdReEk3dElGOW1uNmgwZlVXX2hPVUYxaHdDNThaZlh1b3hCZjRBZ1M0NkV1TFR3SDg1bHRVdFhScw\u0026q=https%3A%2F%2Fcampsertomaclub.org%2F\u0026v=uLOuMXoCW9w","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbUpyano0Mml2WHpPYXZodFpEN29oOHNDYjdFUXxBQ3Jtc0traTcyMU15czVDbUNrbDU5MzZJcldUenFrRFRIODR4ZHF1QmREUXE4VW15NDZfZnduUXYtYUgxLUdReEk3dElGOW1uNmgwZlVXX2hPVUYxaHdDNThaZlh1b3hCZjRBZ1M0NkV1TFR3SDg1bHRVdFhScw\u0026q=https%3A%2F%2Fcampsertomaclub.org%2F\u0026v=uLOuMXoCW9w","target":"TARGET_NEW_WINDOW","nofollow":true}}}},{"startIndex":559,"length":34,"onTap":{"innertubeCommand":{"clickTrackingParams":"CJ8BEM2rARgBIhMIve-m3f-djwMVCz_xBR2yaTpwSNy3idCXxuvZuAHKAQSipJAw","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa21RVWNMaEQ2Zm