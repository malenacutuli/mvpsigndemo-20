# Supabase configuration (Cloud or self-hosted)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Optional overrides for self-hosted setups
# VITE_SUPABASE_STORAGE_URL=https://your-storage-host/storage/v1
# VITE_SUPABASE_TUS_URL=https://your-storage-host/storage/v1/upload/resumable
# VITE_SUPABASE_FUNCTIONS_URL=https://your-functions-host/functions/v1
# VITE_SUPABASE_WS_URL=wss://your-functions-host

# Feature flags for transcript and caption management
VITE_TRANSCRIPT_LOAD_BYPASS_VIEW=true
VITE_TRANSCRIPT_USE_IDX_CONFLICT=false
VITE_CAPTIONS_AUTO_SEGMENT=true
VITE_ALLOW_IMPORT_OVERWRITE=false
